# 微博Cookie配置
# 获取方法：
# 1. 打开 Chrome，登录 weibo.com
# 2. 按 F12 打开开发者工具
# 3. 切换到 Network 标签
# 4. 刷新页面，随便点击一个请求
# 5. 在 Request Headers 里找到 Cookie 字段，复制整个值

WEIBO_COOKIE=your_cookie_here

# 目标用户UID（在微博个人主页URL中查看）
WEIBO_UID=your_uid_here

# 请求间隔（秒），防止被封
REQUEST_DELAY=2

# 数据库路径
DB_PATH=./data/weibo_backup.db

# 媒体文件保存路径
MEDIA_DIR=./data/media

# 移动端gsid（用于获取PC端API无法获取的历史评论）
# 获取方法：
# 1. 手机安装抓包工具（iOS: Stream/Charles, Android: HttpCanary）
# 2. 打开微博App，随便浏览几个页面
# 3. 在任意请求的URL参数中找到 gsid=... 的值
# 4. 注意：gsid 会过期，和PC端Cookie一样需要定期更新
WEIBO_GSID=your_gsid_here

# 服务端口
SERVER_PORT=8000

# CORS 允许的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
